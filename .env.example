# ── Required ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ── Bot identity ───────────────────────────────────────────────────────────────
BOT_NAME=Team Manager
BOT_DESCRIPTION=Esports team management — roster, availability, calendar & stats

# ── Database ───────────────────────────────────────────────────────────────────
# On Railway: leave this unset — Railway injects DATABASE_URL automatically.
# Locally:    uses SQLite by default (no setup needed).
# DATABASE_URL=sqlite+aiosqlite:///./data/manager.db

# ── Valorant live stats — Henrik Dev API (optional) ────────────────────────────
# Free key at https://docs.henrikdev.xyz
# Without this, /stats commands are disabled.
# HENRIK_API_KEY=

# ── pracc.com sync (optional) ──────────────────────────────────────────────────
# PRACC_SYNC_ENABLED=true
# PRACC_EMAIL=
# PRACC_PASSWORD=

# ── Development ────────────────────────────────────────────────────────────────
# Instant slash command sync to a specific guild (instead of waiting 1h globally)
# GUILD_ID=your_test_server_id

# LOG_LEVEL=INFO
